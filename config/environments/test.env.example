ATLAS_ENV=test
NODE_ENV=test
CONFIG_SCHEMA_VERSION=1
API_CORS_ORIGIN=http://127.0.0.1:3000
API_DEBUG=false
DATABASE_URL=postgresql://atlas:${ATLAS_TEST_DB_PASSWORD}@127.0.0.1:5432/atlas_test
REDIS_URL=redis://127.0.0.1:6379
HEALTH_CHECK_DATABASE=true
OBJECT_STORAGE_ENDPOINT=http://127.0.0.1:9000
OBJECT_STORAGE_BUCKET=atlas-test
OBJECT_STORAGE_ACCESS_KEY_ID=${ATLAS_TEST_OBJECT_ACCESS_KEY}
OBJECT_STORAGE_SECRET_ACCESS_KEY=${ATLAS_TEST_OBJECT_SECRET_KEY}
NEXT_PUBLIC_API_URL=http://127.0.0.1:3001/api/v1
RELEASE_VERSION=test
RELEASE_COMMIT_SHA=0000000
WORKER_ROLE=all
WORKER_HEALTH_FILE=/tmp/atlas-worker-ready
WORKER_DEBUG=false
