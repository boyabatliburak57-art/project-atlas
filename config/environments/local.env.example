ATLAS_ENV=local
NODE_ENV=development
CONFIG_SCHEMA_VERSION=1
API_CORS_ORIGIN=http://localhost:3000
API_DEBUG=false
DATABASE_URL=postgresql://atlas:${ATLAS_LOCAL_DB_PASSWORD}@127.0.0.1:5432/atlas
REDIS_URL=redis://127.0.0.1:6379
HEALTH_CHECK_DATABASE=false
OBJECT_STORAGE_ENDPOINT=http://127.0.0.1:9000
OBJECT_STORAGE_BUCKET=atlas-local
OBJECT_STORAGE_ACCESS_KEY_ID=${ATLAS_LOCAL_OBJECT_ACCESS_KEY}
OBJECT_STORAGE_SECRET_ACCESS_KEY=${ATLAS_LOCAL_OBJECT_SECRET_KEY}
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1
RELEASE_VERSION=development
RELEASE_COMMIT_SHA=development
WORKER_ROLE=all
WORKER_HEALTH_FILE=
WORKER_DEBUG=false
