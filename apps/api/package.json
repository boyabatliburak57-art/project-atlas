{
  "name": "@atlas/api",
  "version": "0.0.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "build": "pnpm --filter @atlas/domain build && tsc -p tsconfig.build.json",
    "dev": "tsx watch src/main.ts",
    "e2e:scanner": "pnpm --filter @atlas/domain build && tsc -p tsconfig.e2e.json && node dist/e2e-server/e2e/scanner-api-server.js",
    "lint": "eslint src",
    "openapi:check": "vitest run src/openapi/openapi.test.ts",
    "start": "node dist/main.js",
    "test": "pnpm --filter @atlas/domain build && vitest run",
    "test:database": "pnpm --filter @atlas/domain build && vitest run --config vitest.database.config.ts",
    "test:portfolio-integration": "pnpm --filter @atlas/domain build && pnpm --filter @atlas/database build && vitest run --config vitest.database.config.ts",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@atlas/config": "workspace:*",
    "@nestjs/testing": "11.1.28",
    "@types/express": "5.0.6",
    "@types/node": "26.1.1",
    "@types/supertest": "7.2.0",
    "supertest": "7.2.2",
    "tsx": "4.23.0",
    "vitest": "4.1.10"
  },
  "dependencies": {
    "@atlas/database": "workspace:*",
    "@atlas/domain": "workspace:*",
    "@atlas/types": "workspace:*",
    "@nestjs/common": "11.1.28",
    "@nestjs/config": "4.0.4",
    "@nestjs/core": "11.1.28",
    "@nestjs/platform-express": "11.1.28",
    "@nestjs/swagger": "11.4.5",
    "bullmq": "5.80.1",
    "drizzle-orm": "0.45.2",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2",
    "zod": "4.4.3"
  }
}
