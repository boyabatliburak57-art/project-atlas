{
  "name": "@atlas/worker",
  "version": "0.0.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "build": "pnpm --filter @atlas/types build && tsc -p tsconfig.build.json",
    "dev": "pnpm --filter @atlas/types build && tsx watch src/main.ts",
    "lint": "eslint src",
    "perf:scanner": "tsx src/performance/scanner-runtime-benchmark.ts",
    "perf:alerts": "tsx src/performance/alerts-watchlists-benchmark.ts",
    "perf:backtest": "tsx src/performance/backtest-benchmark.ts",
    "perf:portfolio": "tsx src/performance/portfolio-risk-benchmark.ts",
    "perf:patterns": "tsx src/performance/market-pattern-benchmark.ts",
    "start": "node dist/main.js",
    "test": "pnpm --filter @atlas/types build && vitest run",
    "test:integration": "pnpm --filter @atlas/types build && vitest run --config vitest.integration.config.ts",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@atlas/config": "workspace:*",
    "@types/node": "26.1.1",
    "tsx": "4.23.0",
    "vitest": "4.1.10"
  },
  "dependencies": {
    "@atlas/database": "workspace:*",
    "@atlas/domain": "workspace:*",
    "@atlas/types": "workspace:*",
    "bullmq": "5.80.1",
    "dotenv": "17.4.2",
    "drizzle-orm": "0.45.2",
    "ioredis": "5.10.1",
    "zod": "4.4.3"
  }
}
