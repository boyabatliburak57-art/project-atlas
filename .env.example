# Local Docker Compose infrastructure
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=atlas
POSTGRES_USER=atlas
POSTGRES_PASSWORD=replace-with-a-local-password

REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# Application connection examples
DATABASE_URL=postgresql://atlas:replace-with-a-local-password@127.0.0.1:5432/atlas
TEST_DATABASE_URL=postgresql://atlas:replace-with-a-local-password@127.0.0.1:5432/atlas_test
REDIS_URL=redis://127.0.0.1:6379

# Web application public configuration (never put secrets in NEXT_PUBLIC_* variables)
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1

# API application
NODE_ENV=development
API_HOST=0.0.0.0
API_PORT=3001
API_CORS_ORIGIN=http://localhost:3000
LOG_LEVEL=log

# Worker application
WORKER_CONCURRENCY=2
WORKER_HEARTBEAT_INTERVAL_MS=30000
WORKER_LOG_LEVEL=info
WORKER_STARTUP_TIMEOUT_MS=10000
