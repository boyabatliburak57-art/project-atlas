{
  "name": "@atlas/database",
  "version": "0.0.0",
  "private": true,
  "type": "commonjs",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema/index.ts"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "db:check": "drizzle-kit check",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/cli/migrate.ts",
    "db:seed": "tsx src/cli/seed.ts",
    "lint": "eslint src drizzle.config.ts",
    "test": "vitest run --config vitest.config.ts",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "dotenv": "17.4.2",
    "drizzle-orm": "0.45.2",
    "pg": "8.22.0"
  },
  "devDependencies": {
    "@types/node": "26.1.1",
    "@types/pg": "8.20.0",
    "drizzle-kit": "0.31.10",
    "tsx": "4.23.0",
    "vitest": "4.1.10"
  }
}
